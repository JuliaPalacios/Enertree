foldid = foldid,
variation = "Group LASSO",
layout = "feature_group",
lambda = lambda_choice,
scenario = scenario_name,
sparsegl_asparse = sparsegl_asparse,
snr = sim$snr,
noise_variance = sim$noise_variance,
signal_variance = sim$signal_variance,
include_details = rep == 1
)
lasso_fit <- run_ewma_experiment(
Zmat = dataset$Zmats$time_group,
y = y,
alpha_mat = alpha_mat,
T_rho = T_rho,
p = p,
foldid = foldid,
variation = "LASSO",
layout = "time_group",
lambda = lambda_choice,
scenario = scenario_name,
sparsegl_asparse = sparsegl_asparse,
snr = sim$snr,
noise_variance = sim$noise_variance,
signal_variance = sim$signal_variance,
include_details = rep == 1
)
sparsegl_time_group_fit <- run_ewma_experiment(
Zmat = dataset$Zmats$time_group,
y = y,
alpha_mat = alpha_mat,
T_rho = T_rho,
p = p,
foldid = foldid,
variation = "Sparse Group LASSO",
layout = "time_group",
lambda = lambda_choice,
scenario = scenario_name,
sparsegl_asparse = sparsegl_asparse,
snr = sim$snr,
noise_variance = sim$noise_variance,
signal_variance = sim$signal_variance,
include_details = rep == 1
)
sparsegl_predictor_group_fit <- run_ewma_experiment(
Zmat = dataset$Zmats$feature_group,
y = y,
alpha_mat = alpha_mat,
T_rho = T_rho,
p = p,
foldid = foldid,
variation = "Sparse Group LASSO",
layout = "feature_group",
lambda = lambda_choice,
scenario = scenario_name,
sparsegl_asparse = sparsegl_asparse,
snr = sim$snr,
noise_variance = sim$noise_variance,
signal_variance = sim$signal_variance,
include_details = rep == 1
)
summary_tables[[5 * rep - 4L]] <- time_group_fit$summary_table
summary_tables[[5 * rep - 3L]] <- predictor_group_fit$summary_table
summary_tables[[5 * rep - 2L]] <- lasso_fit$summary_table
summary_tables[[5 * rep - 1L]] <- sparsegl_time_group_fit$summary_table
summary_tables[[5 * rep]] <- sparsegl_predictor_group_fit$summary_table
if (rep == 1) {
detail_result <- list(
time_group = time_group_fit,
predictor_group = predictor_group_fit,
lasso = lasso_fit,
sparsegl_time_group = sparsegl_time_group_fit,
sparsegl_predictor_group = sparsegl_predictor_group_fit
)
}
update_progress_bar(progress_bar, rep)
}
summary_table <- aggregate_replicate_summaries(summary_tables)
detail_result$time_group$summary_table <- summary_table[summary_table$method == "Group Lasso (Time Groups)", , drop = FALSE]
detail_result$predictor_group$summary_table <- summary_table[summary_table$method == "Group Lasso (Predictor Groups)", , drop = FALSE]
detail_result$lasso$summary_table <- summary_table[summary_table$method == "LASSO", , drop = FALSE]
detail_result$sparsegl_time_group$summary_table <- summary_table[summary_table$method == "Sparse Group Lasso (Time Groups)", , drop = FALSE]
detail_result$sparsegl_predictor_group$summary_table <- summary_table[summary_table$method == "Sparse Group Lasso (Predictor Groups)", , drop = FALSE]
c(list(summary_table = summary_table), detail_result)
}
write_ewma_group_sparsegl_comparison <- function(
output_root,
scenario_name,
time_group_fit,
predictor_group_fit,
sparsegl_time_group_fit,
sparsegl_predictor_group_fit
) {
time_group_comparison <- compare_group_and_sparsegl_coefficients(
group_table = time_group_fit$comparison_table,
sparsegl_table = sparsegl_time_group_fit$comparison_table,
layout = "time_group"
)
predictor_group_comparison <- compare_group_and_sparsegl_coefficients(
group_table = predictor_group_fit$comparison_table,
sparsegl_table = sparsegl_predictor_group_fit$comparison_table,
layout = "feature_group"
)
combined_comparison <- rbind(time_group_comparison, predictor_group_comparison)
scenario_dir <- file.path(output_root, sanitize_path_component(scenario_name))
write_table_csv(
combined_comparison,
file.path(scenario_dir, "group_vs_sparsegl_comparison.csv")
)
combined_comparison
}
