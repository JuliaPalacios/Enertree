standardize_cvxr_summary <- function(summary_table, scenario, method, verification_model) {
if (is.null(summary_table)) {
return(NULL)
}
if (verification_model == "Adelie") {
data.frame(
scenario = scenario,
method = method,
verification_model = verification_model,
n_groups = summary_table$n_groups,
objective_model = summary_table$objective_adelie,
objective_cvxr = summary_table$objective_cvxr,
objective_gap = abs(summary_table$objective_adelie - summary_table$objective_cvxr),
n_zero_model = summary_table$n_zero_adelie,
n_zero_cvxr = summary_table$n_zero_cvxr,
n_nonzero_model = summary_table$n_nonzero_adelie,
n_nonzero_cvxr = summary_table$n_nonzero_cvxr,
zero_tol = summary_table$zero_tol,
asparse = NA_real_,
lambda = summary_table$lambda,
family = summary_table$family,
solver = summary_table$solver,
status = summary_table$status,
n = summary_table$n,
p = summary_table$p,
stringsAsFactors = FALSE,
row.names = NULL
)
} else {
data.frame(
scenario = scenario,
method = method,
verification_model = verification_model,
n_groups = summary_table$n_groups,
objective_model = summary_table$objective_sparsegl,
objective_cvxr = summary_table$objective_cvxr,
objective_gap = abs(summary_table$objective_sparsegl - summary_table$objective_cvxr),
n_zero_model = summary_table$n_zero_sparsegl,
n_zero_cvxr = summary_table$n_zero_cvxr,
n_nonzero_model = summary_table$n_nonzero_sparsegl,
n_nonzero_cvxr = summary_table$n_nonzero_cvxr,
zero_tol = summary_table$zero_tol,
asparse = summary_table$asparse,
lambda = summary_table$lambda,
family = summary_table$family,
solver = summary_table$solver,
status = summary_table$status,
n = summary_table$n,
p = summary_table$p,
stringsAsFactors = FALSE,
row.names = NULL
)
}
}
