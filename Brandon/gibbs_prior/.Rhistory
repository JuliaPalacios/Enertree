scenario_results[["sparse_time_sparse_predictor"]]$lasso$adelie_cvxr_summary_table,
"sparse_time_sparse_predictor",
"LASSO",
"Adelie"
),
standardize_cvxr_summary(
scenario_results[["sparse_time_sparse_predictor"]]$sparsegl_time_group$sparsegl_cvxr_summary_table,
"sparse_time_sparse_predictor",
"Sparse Group Lasso (Time Groups)",
"Sparse Group Lasso"
),
standardize_cvxr_summary(
scenario_results[["sparse_time_sparse_predictor"]]$sparsegl_predictor_group$sparsegl_cvxr_summary_table,
"sparse_time_sparse_predictor",
"Sparse Group Lasso (Predictor Groups)",
"Sparse Group Lasso"
)
)
write_table_csv(
cvxr_summary_table,
file.path(output_root, "combined", "cvxr_summary_table.csv")
)
kable(cvxr_summary_table, digits = 3)
